<Window x:Class="MousePoint.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MousePoint"
        WindowStyle="None"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid>
        <!-- 하위 레이어: 완성된 스트로크, 레이저 trail, 인디케이터 등 -->
        <Canvas x:Name="OverlayCanvas"
                Background="Transparent"
                IsHitTestVisible="False" />
        <!-- 상위 레이어: 현재 드래그 중인 형광펜 스트로크만 (변경 빈번) -->
        <Canvas x:Name="ActiveCanvas"
                Background="Transparent"
                IsHitTestVisible="False" />
    </Grid>
</Window>
